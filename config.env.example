# Скопируйте в config.env и заполните. Файл config.env в git не коммитится.
#
# LLM через ProxyAPI (как в lse): можно взять те же OPENAI_API_KEY и OPENAI_BASE_URL
# из ../lse/config.env — либо symlink:  ln -s ../lse/config.env config.env
# либо переменная NYSE_CONFIG_PATH=/абсолютный/путь/к/lse/config.env

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0
OPENAI_TIMEOUT=60

# --- Structured LLM (как pystockinvest agent/news|market|calendar) ---
# По умолчанию выключено: техника — эвристики, календарь — нейтральный сигнал без LLM.
# NYSE_LLM_TECHNICAL=1
# NYSE_LLM_CALENDAR=1
# NYSE_CALENDAR_LLM_BATCH_SIZE=   # пусто = все события в одном запросе; иначе размер чанка

# Опционально: Marketaux, NewsAPI, Alpha Vantage (как в lse)
# MARKETAUX_API_KEY=
# NEWSAPI_KEY=
# ALPHAVANTAGE_KEY=

# Локальный сентимент (FinBERT / HuggingFace), если у статьи нет raw_sentiment с API
# SENTIMENT_MODEL=ProsusAI/finbert
# NYSE_SENTIMENT_LOCAL=true
# NYSE_SENTIMENT_CACHE_TTL_SEC=86400

# Окно HIGH-календаря для гейта (этап C): за сколько минут до и после релиза считать «скоро»
# NYSE_CALENDAR_HIGH_BEFORE_MIN=120
# NYSE_CALENDAR_HIGH_AFTER_MIN=60

# Файловый кэш (этап E): сырьё новостей и агрегаты
# NYSE_CACHE_ROOT=
# NYSE_NEWS_RAW_TTL_SEC=1800
# NYSE_NEWS_AGGREGATE_TTL_SEC=1800

# Кэш ответов LLM: новости, техника, календарь — ключ по хешу промпта+модели (llm_cache.py)
# NYSE_LLM_CACHE_TTL_SEC=86400

# Пороги pipeline (переопределяют дефолты ThresholdConfig), см. docs/calibration.md
# NYSE_GATE_T1=0.20
# NYSE_GATE_T2=0.5

# Кластеризация REG по теме для draft_impulse / гейта (LLM по-прежнему видит все статьи)
# NYSE_REGIME_CLUSTER=1
# NYSE_REGIME_CLUSTER_THRESHOLD=0.88
# NYSE_REGIME_CLUSTER_EMBED=tfidf
# NYSE_REGIME_CLUSTER_EMBEDDING_MODEL=text-embedding-3-small

# --- Telegram-бот и интеграционные тесты (tests/integration/test_telegram_bot_smoke.py) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_PROXY=socks5h://127.0.0.1:1080
# Чат для sendMessage в smoke-тестах (один id или первый из списка):
# TELEGRAM_SIGNAL_CHAT_ID=123456789
# TELEGRAM_SIGNAL_CHAT_IDS=123,456
