# Скопируйте в config.env и заполните. Файл config.env в git не коммитится.
#
# LLM через ProxyAPI (как в lse): можно взять те же OPENAI_API_KEY и OPENAI_BASE_URL
# из ../lse/config.env — либо symlink:  ln -s ../lse/config.env config.env
# либо переменная NYSE_CONFIG_PATH=/абсолютный/путь/к/lse/config.env

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0
OPENAI_TIMEOUT=60

# Опционально: Marketaux, NewsAPI (когда подключите адаптеры)
# MARKETAUX_API_KEY=
# NEWSAPI_KEY=

# Пороги pipeline (переопределяют дефолты ThresholdConfig)
# NYSE_GATE_T1=0.25
# NYSE_GATE_T2=0.5
